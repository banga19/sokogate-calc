{
  "name": "sokogate-construction-calculator",
  "version": "2.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development node src/server.js",
    "build": "cd client && npm run build",
    "build:server": "NODE_ENV=production npm run build && NODE_ENV=production node src/server.js",
    "client": "cd client && npm run dev",
    "client:install": "cd client && npm install",
    "dev:concurrently": "concurrently \"NODE_ENV=development node src/server.js\" \"cd client && npm run dev\"",
    "client:install": "cd client && npm install",
    "lint": "eslint .",
    "test": "node healthcheck.js",
    "setup": "npm install && npm run client:install",
    "setup:full": "npm run setup && npm run build"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "mongoose": "^8.4.5",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
