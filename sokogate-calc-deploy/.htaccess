# Sokogate-Calc — WordPress Integration Configuration
# Place this .htaccess inside the /Calculate/ directory for iframe deployment
# For WordPress page integration at https://ultimotradingltd.co.ke/Calculate/

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Set the base for all relative rewrites to the subfolder path
    RewriteBase /Calculate/

    # 1. Allow direct access to actual files (CSS, JS, images, fonts, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. For Node.js/Express: proxy requests to the app
    # When using iframe integration, uncomment the line below:
    # RewriteRule ^(.*)$ http://127.0.0.1:3000/$1 [P,L]

    # 3. Alternative: For static export (if app is converted to static)
    # Uncomment the line below ONLY if serving a pre-built static SPA:
    # RewriteRule ^ index.html [L]
</IfModule>

# Enable long-term caching for static assets
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
</IfModule>

# Prevent access to sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deny access to backup files
<FilesMatch "\.(backup|bak|tar\.gz|zip)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Set default charset
AddDefaultCharset UTF-8
