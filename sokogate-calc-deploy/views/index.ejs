<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sokogate — Construction Materials Calculator</title>
  <meta name="description" content="Calculate cement, sand, bricks, concrete, tiles, steel, paint, gravel, and roofing materials for your construction project.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css?v=1.0.5">
  <style>
    /* Fallback inline styles if CSS fails to load */
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; background: #f1f5f9; }
    .app-wrapper { max-width: 1200px; margin: 0 auto; padding: 20px; }
    .card { background: #fff; border-radius: 12px; padding: 24px; margin-bottom: 24px; box-shadow: 0 4px 6px rgba(0,0,0,0.07); }
    .hero { text-align: center; padding: 40px 0; }
    .hero h1 { font-size: 2.25rem; color: #0f172a; margin-bottom: 8px; }
    .hero-subtitle { color: #475569; font-size: 1.125rem; margin-bottom: 24px; }
    .form-group { margin-bottom: 20px; }
    .form-label { display: block; font-weight: 600; margin-bottom: 8px; color: #0f172a; }
    .form-input, .form-select { width: 100%; padding: 12px 16px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 16px; }
    .form-input:focus, .form-select:focus { border-color: #f59e0b; outline: none; }
    .btn { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; border: none; padding: 14px 24px; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; width: 100%; }
    .btn:hover { opacity: 0.95; }
    .main-grid { display: grid; gap: 24px; }
    @media (min-width: 1024px) { .main-grid { grid-template-columns: 1fr 1fr; } }
    .result-item { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #f1f5f9; }
    .result-item:last-child { border-bottom: none; }
    .label { color: #475569; font-weight: 500; }
    .value { color: #0f172a; font-weight: 600; font-family: monospace; }
  </style>
</head>
<body>
  <div class="app-wrapper">
    <header class="card">
      <h1 style="margin: 0 0 4px 0; font-size: 24px;">Sokogate Materials Calculator</h1>
    </header>
    
    <section class="hero">
      <h1>Construction Materials Calculator</h1>
      <p class="hero-subtitle">Accurately estimate cement, sand, bricks, concrete, tiles, steel, paint, and more for your next build.</p>
    </section>

    <main class="main-grid">
      <div class="card">
        <h2 style="margin: 0 0 16px 0; font-size: 20px;">Project Details</h2>
        <form action="<%= typeof basePath !== 'undefined' && basePath ? basePath + '/calculate' : '/calculate' %>" method="POST" id="calcForm">
          <div class="form-group">
            <label class="form-label">Area (sq ft)</label>
            <input type="number" name="area" id="area" class="form-input" required min="1" step="0.01" placeholder="e.g. 500">
          </div>

          <div class="form-group">
            <label class="form-label">Material Type</label>
            <select name="materialType" id="materialType" class="form-select" required>
              <option value="" disabled selected>Select material...</option>
              <optgroup label="Masonry">
                <option value="bricks">Bricks (9" × 4.5")</option>
                <option value="blocks">Concrete Blocks (8" × 8" × 16")</option>
              </optgroup>
              <optgroup label="Concrete & Cement">
                <option value="cement">Cement & Sand Plastering</option>
                <option value="concrete">Concrete Slab (1:2:4 Mix)</option>
                <option value="steel">Reinforcement Steel</option>
              </optgroup>
              <optgroup label="Finishing">
                <option value="tiles">Floor/Wall Tiles</option>
                <option value="painting">Interior Painting</option>
                <option value="roofing">Metal Roofing</option>
              </optgroup>
              <optgroup label="Site Works">
                <option value="gravel">Crushed Stone / Gravel</option>
              </optgroup>
</select>
           </div>

           <div class="form-group" id="thicknessGroup" style="display: none;">
             <label class="form-label">Thickness (inches)</label>
             <input type="number" name="thickness" class="form-input" min="1" step="0.5" placeholder="e.g. 4" value="4">
             <span class="field-hint">For concrete slabs (default 4") or steel (default 4mm per sq ft)</span>
           </div>

           <div class="form-group" id="tileSizeGroup" style="display: none;">
             <label class="form-label">Tile Size (inches)</label>
             <select name="tileSize" class="form-select">
               <option value="12">12" × 12" (1 sq ft)</option>
               <option value="16">16" × 16" (1.78 sq ft)</option>
               <option value="18">18" × 18" (2.25 sq ft)</option>
               <option value="24">24" × 24" (4 sq ft)</option>
             </select>
           </div>

           <div class="form-group" id="roomDimensions" style="display: none;">
             <label class="form-label">Room Dimensions (ft)</label>
             <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
               <input type="number" name="roomWidth" id="roomWidth" class="form-input" placeholder="Width" step="0.1">
               <input type="number" name="roomLength" id="roomLength" class="form-input" placeholder="Length" step="0.1">
               <input type="number" name="roomHeight" id="roomHeight" class="form-input" placeholder="Height (optional)" step="0.1">
             </div>
           </div>

           <button type="submit" class="btn">Calculate Materials</button>
        </form>
      </div>

      <div class="card">
        <h2 style="margin: 0 0 16px 0; font-size: 20px;">Calculation Results</h2>
        <% if (typeof result !== 'undefined' && result) { %>
          <% if (result.error) { %>
            <div style="background: #fee2e2; border: 1px solid #fecaca; padding: 16px; border-radius: 8px; color: #dc2626;">
              <%= result.error %>
            </div>
          <% } else { %>
            <% if (result.cement) { %><div class="result-item"><span class="label">Cement</span><span class="value"><%= result.cement %></span></div><% } %>
            <% if (result.sand) { %><div class="result-item"><span class="label">Sand</span><span class="value"><%= result.sand %></span></div><% } %>
            <% if (result.bricks) { %><div class="result-item"><span class="label">Bricks</span><span class="value"><%= result.bricks %></span></div><% } %>
            <% if (result.concrete) { %><div class="result-item"><span class="label">Concrete</span><span class="value"><%= result.concrete %></span></div><% } %>
            <% if (result.steel) { %><div class="result-item"><span class="label">Steel</span><span class="value"><%= result.steel %></span></div><% } %>
            <% if (result.tiles) { %><div class="result-item"><span class="label">Tiles</span><span class="value"><%= result.tiles %></span></div><% } %>
            <% if (result.paint) { %><div class="result-item"><span class="label">Paint</span><span class="value"><%= result.paint %></span></div><% } %>
          <% } %>
        <% } else { %>
          <p style="color: #475569; text-align: center; padding: 40px 0;">Enter project details and click <strong>Calculate Materials</strong> to see estimates.</p>
        <% } %>
      </div>
    </main>
  </div>
  <script src="/script.js"></script>
</body>
</html>