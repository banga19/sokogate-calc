<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sokogate Construction Materials Calculator</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <header>
      <h1>Construction Materials Calculator</h1>
      <p class="subtitle">Calculate cement, sand, bricks, and more for your construction project</p>
    </header>

    <main>
      <form action="/sokogate-calc/calculate" method="POST" id="calcForm">
        <div class="form-group">
          <label for="area">Area (sq ft)</label>
          <input 
            type="number" 
            id="area" 
            name="area" 
            required 
            min="1" 
            step="0.01" 
            placeholder="Enter area in square feet"
            autocomplete="off"
          >
        </div>

        <div class="form-group">
          <label for="materialType">Material Type</label>
          <select id="materialType" name="materialType" required>
            <option value="">Select material</option>
            <optgroup label="Masonry">
              <option value="cement">Cement & Sand (Plastering)</option>
              <option value="bricks">Bricks (Wall - 9x4.5 inch)</option>
              <option value="blocks">Concrete Blocks (8x8x16 inch)</option>
            </optgroup>
            <optgroup label="Concrete & Reinforcement">
              <option value="concrete">Concrete Slab</option>
              <option value="steel">Reinforcement Steel</option>
            </optgroup>
            <optgroup label="Finishes">
              <option value="tiles">Floor/Wall Tiles</option>
              <option value="painting">Paint (Interior)</option>
            </optgroup>
            <optgroup label="Landscaping">
              <option value="gravel">Crushed Stone / Gravel</option>
            </optgroup>
            <optgroup label="Roofing">
              <option value="roofing">Metal Roofing Sheets</option>
            </optgroup>
          </select>
        </div>

        <!-- Thickness Field (shown for concrete & steel) -->
        <div class="form-group" id="thicknessGroup" style="display: none;">
          <label for="thickness">Thickness (inches)</label>
          <input 
            type="number" 
            id="thickness" 
            name="thickness" 
            min="1" 
            max="12" 
            step="0.5" 
            value="4" 
            placeholder="Slab thickness (4 = 4 inch)"
          >
          <small class="field-hint">Standard concrete slab: 4-6 inches</small>
        </div>

        <!-- Tile Size Field (shown for tiles) -->
        <div class="form-group" id="tileSizeGroup" style="display: none;">
          <label for="tileSize">Tile Size (inches)</label>
          <select id="tileSize" name="tileSize">
            <option value="12">12 x 12 inch</option>
            <option value="18">18 x 18 inch</option>
            <option value="24">24 x 24 inch</option>
            <option value="6">6 x 6 inch (mosaic)</option>
          </select>
          <small class="field-hint">10% wastage included automatically</small>
        </div>

        <button type="submit" class="btn">Calculate Materials</button>
      </form>

      <% if (typeof result !== 'undefined' && result) { %>
        <section class="results">
          <h2>Results</h2>
          <% if (result.error) { %>
            <div class="error">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="10" cy="10" r="8"/>
                <line x1="10" y1="6" x2="10" y2="14"/>
                <line x1="10" y1="14" x2="14" y2="10"/>
              </svg>
              <span><%= result.error %></span>
            </div>
          <% } else { %>
            <div class="result-summary">
              <span class="material-type-badge"><%= result.materialType || 'Material Calculation' %></span>
            </div>
            <% if (result.tiles) { %>
              <div class="result-item">
                <span class="label">Tiles Required</span>
                <span class="value highlight"><%= result.tiles %></span>
              </div>
            <% } %>
            <% if (result.tileArea) { %>
              <div class="result-item">
                <span class="label">Total Tile Area</span>
                <span class="value"><%= result.tileArea %></span>
              </div>
            <% } %>
            <% if (result.adhesive) { %>
              <div class="result-item">
                <span class="label">Tile Adhesive</span>
                <span class="value"><%= result.adhesive %></span>
              </div>
            <% } %>
            <% if (result.grout) { %>
              <div class="result-item">
                <span class="label">Tile Grout</span>
                <span class="value"><%= result.grout %></span>
              </div>
            <% } %>
            <% if (result.bricks) { %>
              <div class="result-item">
                <span class="label">Bricks</span>
                <span class="value highlight"><%= result.bricks %></span>
              </div>
            <% } %>
            <% if (result.blocks) { %>
              <div class="result-item">
                <span class="label">Concrete Blocks</span>
                <span class="value highlight"><%= result.blocks %></span>
              </div>
            <% } %>
            <% if (result.cement) { %>
              <div class="result-item">
                <span class="label">Cement (50kg bags)</span>
                <span class="value"><%= result.cement %></span>
              </div>
            <% } %>
            <% if (result.sand) { %>
              <div class="result-item">
                <span class="label">Sand</span>
                <span class="value"><%= result.sand %></span>
              </div>
            <% } %>
            <% if (result.concrete) { %>
              <div class="result-item">
                <span class="label">Concrete Volume</span>
                <span class="value highlight"><%= result.concrete %></span>
              </div>
            <% } %>
            <% if (result.aggregate) { %>
              <div class="result-item">
                <span class="label">Aggregate</span>
                <span class="value"><%= result.aggregate %></span>
              </div>
            <% } %>
            <% if (result.steel) { %>
              <div class="result-item">
                <span class="label">Steel (Rebar)</span>
                <span class="value highlight"><%= result.steel %></span>
              </div>
            <% } %>
            <% if (result.wireMesh) { %>
              <div class="result-item">
                <span class="label">Wire Mesh</span>
                <span class="value"><%= result.wireMesh %></span>
              </div>
            <% } %>
            <% if (result.paint) { %>
              <div class="result-item">
                <span class="label">Paint</span>
                <span class="value highlight"><%= result.paint %></span>
              </div>
            <% } %>
            <% if (result.primer) { %>
              <div class="result-item">
                <span class="label">Primer</span>
                <span class="value"><%= result.primer %></span>
              </div>
            <% } %>
            <% if (result.gravel) { %>
              <div class="result-item">
                <span class="label">Crushed Stone</span>
                <span class="value highlight"><%= result.gravel %></span>
              </div>
            <% } %>
            <% if (result.geotextile) { %>
              <div class="result-item">
                <span class="label">Geotextile Fabric</span>
                <span class="value"><%= result.geotextile %> sq ft</span>
              </div>
            <% } %>
            <% if (result.roofingSheets) { %>
              <div class="result-item">
                <span class="label">Roofing Sheets</span>
                <span class="value highlight"><%= result.roofingSheets %></span>
              </div>
            <% } %>
            <% if (result.screws) { %>
              <div class="result-item">
                <span class="label">Roofing Screws</span>
                <span class="value"><%= result.screws %></span>
              </div>
            <% } %>
            <% if (result.flashing) { %>
              <div class="result-item">
                <span class="label">Flashing</span>
                <span class="value"><%= result.flashing %> ft</span>
              </div>
            <% } %>
          <% } %>
        </section>
        <div id="3d-container"></div>
      <% } else { %>
        <div id="3d-container"></div>
      <% } %>
    </main>

    <!-- Debug: Show result object if ?debug=1 -->
    <% if (typeof result !== 'undefined' && result && typeof query !== 'undefined' && query.debug) { %>
      <div style="background:#f00;color:#fff;padding:10px;margin-top:20px;font-family:monospace;font-size:12px;">
        <strong>DEBUG:</strong> <pre><%= JSON.stringify(result, null, 2) %></pre>
      </div>
    <% } %>
  </div>

  <script src="/three.min.js"></script>
  <script src="/3d-room.js"></script>
  <script>
    const resultData = <%- typeof result !== 'undefined' ? JSON.stringify(result || null) : 'null' %>;
  </script>
  <script src="/script.js"></script>
</body>
</html>
