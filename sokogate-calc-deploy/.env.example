NODE_ENV=production
# For cPanel subdomain deployments, keep BASE_PATH=/
# If deploying in a subdirectory (e.g., example.com/app), set BASE_PATH=/app
BASE_PATH=/
# App port (cPanel may set PORT=3000; override with APP_PORT if needed)
APP_PORT=3001
# Allowed CORS origin (use your domain)
CORS_ORIGIN=https://ultimotradingltd.co.ke
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
