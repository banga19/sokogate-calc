# Sokogate-Calc — cPanel Deployment Configuration
#
# CRITICAL: If old React files (index.html, assets/) exist in this folder,
# Apache will serve them BEFORE Node.js gets the request.
# Delete them before starting the Node.js app.
#
# In cPanel with Phusion Passenger, most routing is handled by Passenger.
# This .htaccess cleans up stale service workers and adds proxy fallback.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /sokogate-calc/sokogate-calc-deploy/

    # --- 1. Explicitly deny old React build artifacts (410 Gone) ---
    RewriteCond %{REQUEST_URI} ^/sokogate-calc/sokogate-calc-deploy/assets/ [NC,OR]
    RewriteCond %{REQUEST_URI} ^/sokogate-calc/sokogate-calc-deploy/static/ [NC,OR]
    RewriteCond %{REQUEST_URI} ^/sokogate-calc/sokogate-calc-deploy/index\.html$ [NC]
    RewriteRule .* - [G,L]

    # --- 2. Allow direct access to real files (CSS, JS, images) ---
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # --- 3. SPA Fallback: push everything to Node.js entry point ---
    # Uncomment ONLY if running manually behind Apache (not via Passenger):
    # RewriteRule ^(.*)$ http://127.0.0.1:3000/$1 [P,L]
</IfModule>

# --- Disable service workers & stale caches for this path ---
<IfModule mod_headers.c>
    <FilesMatch "sw\.js|service-worker\.js|workbox-.*\.js">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
</IfModule>

# --- Security headers ---
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- Deny access to sensitive files ---
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "\.(backup|bak|tar\.gz|zip|log|env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]


AddDefaultCharset UTF-8
